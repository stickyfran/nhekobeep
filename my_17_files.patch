+void
+RoomlistModel::updateNetworkCache(const QString &roomid)
+{
+    bool isBeeperBridge = false;
+    QString counterpart;
+    BeeperNetworkInfo netInfo;
+    int realContacts = 0;
+
+    if (models.contains(roomid)) {
+        auto local = cache::client()->localUserId();
+        auto members = cache::client()->getMembers(roomid.toStdString());
+
+        for (const auto &m : members) {
+            if (m.user_id == local) continue;
+            QString mxid = m.user_id;
+            if (mxid.contains("bot", Qt::CaseInsensitive) && mxid.contains(":beeper.")) {
+                isBeeperBridge = true;
+                netInfo = beeperNetworkFromMxid(mxid);
+            } else {
+                realContacts++;
+                if (counterpart.isEmpty()) counterpart = mxid;
+            }
+        }
+    }
+
+    if (isBeeperBridge) {
+        if (realContacts > 1) {
+            networkCache.insert(roomid, {netInfo.name, netInfo.color, QString(), 999});
+        } else {
+            networkCache.insert(roomid, {netInfo.name, netInfo.color, counterpart, 1});
+        }
+        return;
+    }
+
+    if (directChatToUser.count(roomid)) {
+        const auto &userId = directChatToUser.at(roomid).front();
+        auto info = beeperNetworkFromMxid(userId);
+        networkCache.insert(roomid, {info.name, info.color, userId, 1});
+        return;
+    }
+
+    networkCache.insert(roomid, {QString(), QColor(), QString(), 0});
+}
+
+void
+RoomlistModel::rebuildNetworkCache()
+{
+    networkCache.clear();
+    networkCache.reserve(static_cast<int>(roomids.size()));
+}
