+// -----------------------------------------------------------------------
+// Space CRUD
+// -----------------------------------------------------------------------
+void
+CommunitiesModel::createSpace(const QString &name, const QString &topic, const QString &avatarUrl, bool isPublic)
+{
+    mtx::requests::CreateRoom req;
+    req.name          = name.toStdString();
+    req.topic         = topic.toStdString();
+    req.creation_content       = mtx::events::state::Create{};
+    req.creation_content->type = mtx::events::state::room_type::space;
+    req.preset        = isPublic ? mtx::requests::Preset::PublicChat : mtx::requests::Preset::PrivateChat;
+
+    if (!avatarUrl.isEmpty()) {
+        mtx::events::StrippedEvent<mtx::events::state::Avatar> avatarEvent;
+        avatarEvent.type              = mtx::events::EventType::RoomAvatar;
+        avatarEvent.content.url = avatarUrl.toStdString();
+        req.initial_state.emplace_back(std::move(avatarEvent));
+    }
+
+    http::client()->create_room(
+      req,
+      [this](const mtx::responses::CreateRoom &res, mtx::http::RequestErr err) {
+          if (err) {
+              QString msg = QString::fromStdString(err->matrix_error.error);
+              nhlog::ui()->error("Failed to create space: {}", msg.toStdString());
+              emit spaceError(tr("Failed to create space: %1").arg(msg));
+              return;
+          }
+          QString roomId = QString::fromStdString(res.room_id.to_string());
+          nhlog::ui()->info("Created space: {}", roomId.toStdString());
+          initializeSidebar();
+          emit spaceCreated(roomId);
+      });
+}
+
+void
+CommunitiesModel::updateSpace(const QString &spaceId, const QString &name, const QString &topic, const QString &avatarUrl)
+{
+    auto room_id = spaceId.toStdString();
+
+    // Send m.room.name if provided
+    if (!name.isEmpty()) {
+        mtx::events::state::Name nameEvent;
+        nameEvent.name = name.toStdString();
+        http::client()->send_state_event(
+          room_id, nameEvent, [spaceId](const mtx::responses::EventId &, mtx::http::RequestErr err) {
+              if (err)
+                  nhlog::ui()->error("Failed to update space name: {}",
+                                     err->matrix_error.error);
+          });
+    }
+
+    // Send m.room.topic if provided
+    if (!topic.isEmpty()) {
+        mtx::events::state::Topic topicEvent;
+        topicEvent.topic = topic.toStdString();
+        http::client()->send_state_event(
+          room_id, topicEvent, [spaceId](const mtx::responses::EventId &, mtx::http::RequestErr err) {
+              if (err)
+                  nhlog::ui()->error("Failed to update space topic: {}",
+                                     err->matrix_error.error);
+          });
+    }
+
+    // Send m.room.avatar if provided
+    if (!avatarUrl.isEmpty()) {
+        mtx::events::state::Avatar avatarEvent;
+        avatarEvent.url = avatarUrl.toStdString();
+        http::client()->send_state_event(
+          room_id, avatarEvent, [spaceId](const mtx::responses::EventId &, mtx::http::RequestErr err) {
+              if (err)
+                  nhlog::ui()->error("Failed to update space avatar: {}",
+                                     err->matrix_error.error);
+          });
+    }
+
+    emit spaceUpdated(spaceId);
+}
+
+void
+CommunitiesModel::deleteSpace(const QString &spaceId)
+{
+    // Leave the space room
+    ChatPage::instance()->leaveRoom(spaceId, QStringLiteral("Space deleted"));
+    emit spaceDeleted(spaceId);
+    initializeSidebar();
+}
