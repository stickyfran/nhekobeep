+QVariant
+CustomLabelListModel::data(const QModelIndex &index, int role) const
+{
+    if (index.row() < 0 || index.row() >= labels_.size())
+        return {};
+
+    const auto &label = labels_.at(index.row());
+    switch (role) {
+    case TagRole:
+        return label.tag;
+    case DisplayNameRole:
+        return label.displayName;
+    case IconKeyRole:
+        return label.iconKey;
+    default:
