+void
+RoomlistModel::updateNetworkCache(const QString &roomid)
+{
+    // 1. Check standard DMs
+    if (directChatToUser.count(roomid)) {
+        const auto &userId = directChatToUser.at(roomid).front();
+        auto info          = beeperNetworkFromMxid(userId);
+        networkCache.insert(roomid, {info.name, info.color, userId});
+        return;
+    }
+
+    // 2. Check Beeper bridged rooms (Both DMs and Groups)
+    if (models.contains(roomid)) {
+        auto local = cache::client()->localUserId();
+        // Fetch all members. LMDB read is extremely fast.
+        auto members = cache::client()->getMembers(roomid.toStdString());
+
+        bool isBeeperBridge = false;
+        QString counterpart;
+        BeeperNetworkInfo netInfo;
+        int activeMembers = 0;
+
+        for (const auto &m : members) {
+            if (m.user_id == local)
+                continue;
+            activeMembers++;
+
+            QString mxid = m.user_id;
+            if (mxid.contains(QStringLiteral("bot"), Qt::CaseInsensitive) &&
+                mxid.contains(QStringLiteral(":beeper."))) {
+                isBeeperBridge = true;
+                netInfo        = beeperNetworkFromMxid(mxid);
+            } else if (counterpart.isEmpty()) {
+                counterpart = mxid;
+            }
+        }
+
+        if (isBeeperBridge) {
+            if (activeMembers <= 2) {
+                // It's a 1:1 DM (Local + Bot + 1 Real Contact)
+                networkCache.insert(roomid, {netInfo.name, netInfo.color, counterpart});
+            } else {
+                // It's a Group Chat (Local + Bot + 2+ Real Contacts)
+                networkCache.insert(roomid, {netInfo.name, netInfo.color, QString()});
+            }
+            return;
+        }
+    }
+
+    // No bridge detected
+    networkCache.insert(roomid, {QString(), QColor(), QString()});
+}
+
+void
+RoomlistModel::rebuildNetworkCache()
+{
+    networkCache.clear();
+    networkCache.reserve(static_cast<int>(roomids.size()));
+    for (const auto &roomid : roomids)
+        updateNetworkCache(roomid);
+}
