+std::map<std::string, BeeperLabel>
+Cache::getBeeperLabels()
+{
+    std::map<std::string, BeeperLabel> labels;
+    if (!this->beeperLabelsCache_.empty()) {
+        return this->beeperLabelsCache_;
+    }
+
+    try {
+        auto txn = ro_txn(this->db->env_);
+        auto db_ = this->getAccountDataDb(txn, "");
+
+        std::string_view data;
+        if (db_.get(txn, "com.beeper.labels", data)) {
+            nlohmann::json j = nlohmann::json::parse(data);
+            if (j.contains("content")) {
+                for (const auto &[key, value] : j["content"].items()) {
+                    labels[key] = value.get<BeeperLabel>();
+                }
+            }
+        }
+        this->beeperLabelsCache_ = labels;
+    } catch (const std::exception &e) {
+        nhlog::db()->error("Failed to parse beeper labels: {}", e.what());
+    }
+    return labels;
+}
