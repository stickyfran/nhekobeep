+void
+UserProfile::downloadChatHistory()
+{
+    QString filePath = QFileDialog::getSaveFileName(
+      nullptr, tr("Save Chat History"), userid_ + "_history.txt", tr("Text Files (*.txt)"));
+
+    if (filePath.isEmpty())
+        return;
+
+    QFile file(filePath);
+    if (!file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+        emit displayError(tr("Could not open file for writing."));
+        return;
+    }
+
+    QTextStream out(&file);
+    out.setEncoding(QStringConverter::Utf8);
+
+    out << "Chat History with " << userid_ << "\n";
+    out << QString("=").repeated(60) << "\n\n";
+
+    // Use the current room's timeline
+    if (model) {
+        auto roomName = model->plainRoomName();
+        out << "--- Room: " << roomName << " (" << roomid_ << ") ---\n\n";
+
+        auto lastMsg = model->lastMessage();
+        out << "Last activity: "
+            << (lastMsg.descriptiveTime.isValid()
+                  ? lastMsg.descriptiveTime.toString("yyyy-MM-dd HH:mm:ss")
+                  : QLatin1String("unknown"))
+            << "\n";
+        out << lastMsg.body << "\n";
+    }
+
+    file.close();
+}
+
