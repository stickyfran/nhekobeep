+QColor
+FilteredRoomlistModel::networkColorForMxid(const QString &mxid) const
+{
+    // Reuse the same beeper prefix lookup logic from the anonymous namespace
+    const auto atPos = mxid.indexOf(QLatin1Char('@'));
+    if (atPos < 0)
+        return {};
+    const auto colonPos = mxid.indexOf(QLatin1Char(':'), atPos + 1);
+    if (colonPos < 0)
+        return {};
+
+    const auto localpart = mxid.mid(atPos + 1, colonPos - atPos - 1);
+
+    // kBeeperPrefixMap logic duplicated inline for access from the method
+    static const QHash<QString, QPair<QString, QColor>> prefixMap = {
+        {"whatsapp_",     {QStringLiteral("WhatsApp"),     QColor(0x25, 0xD3, 0x66)}},
+        {"whatsappgo_",   {QStringLiteral("WhatsApp"),     QColor(0x25, 0xD3, 0x66)}},
+        {"instagram_",    {QStringLiteral("Instagram"),    QColor(0xE1, 0x30, 0x6C)}},
+        {"instagramgo_",  {QStringLiteral("Instagram"),    QColor(0xE1, 0x30, 0x6C)}},
+        {"telegram_",     {QStringLiteral("Telegram"),     QColor(0x2A, 0xAB, 0xEE)}},
+        {"telegramgo_",   {QStringLiteral("Telegram"),     QColor(0x2A, 0xAB, 0xEE)}},
+        {"signal_",       {QStringLiteral("Signal"),       QColor(0x3A, 0x76, 0xF0)}},
+        {"signalgo_",     {QStringLiteral("Signal"),       QColor(0x3A, 0x76, 0xF0)}},
+        {"discord_",      {QStringLiteral("Discord"),      QColor(0x58, 0x65, 0xF2)}},
+        {"discordgo_",    {QStringLiteral("Discord"),      QColor(0x58, 0x65, 0xF2)}},
+        {"facebook_",     {QStringLiteral("Messenger"),    QColor(0x00, 0xB2, 0xFF)}},
+        {"facebookgo_",   {QStringLiteral("Messenger"),    QColor(0x00, 0xB2, 0xFF)}},
+        {"slack_",        {QStringLiteral("Slack"),        QColor(0x4A, 0x15, 0x4B)}},
+        {"slackgo_",      {QStringLiteral("Slack"),        QColor(0x4A, 0x15, 0x4B)}},
+        {"googlechat_",   {QStringLiteral("Google Chat"),  QColor(0x34, 0xA8, 0x53)}},
+        {"googlechatgo_", {QStringLiteral("Google Chat"),  QColor(0x34, 0xA8, 0x53)}},
+        {"sms_",          {QStringLiteral("SMS"),          QColor(0x34, 0xB7, 0xF1)}},
+        {"smsgo_",        {QStringLiteral("SMS"),          QColor(0x34, 0xB7, 0xF1)}},
+        {"imessage_",     {QStringLiteral("iMessage"),     QColor(0x34, 0xC7, 0x59)}},
+        {"imessagego_",   {QStringLiteral("iMessage"),     QColor(0x34, 0xC7, 0x59)}},
+    };
+
+    for (auto it = prefixMap.constBegin(); it != prefixMap.constEnd(); ++it) {
+        if (localpart.startsWith(it.key(), Qt::CaseInsensitive))
+            return it.value().second;
+    }
+
+    return {};
+}
