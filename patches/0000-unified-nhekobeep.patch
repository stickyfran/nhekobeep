+int
+TimelineModel::indexNearTimestamp(qint64 msecsSinceEpoch) const
+{
+    using namespace mtx::accessors;
+    if (events.size() == 0)
+        return -1;
+
+    int low = 0;
+    int high = events.size() - 1;
+    int closestIdx = -1;
+    qint64 minDiff = std::numeric_limits<qint64>::max();
+
+    while (low <= high) {
+        int mid = low + (high - low) / 2;
+        auto event = events.get(mid, false);
+        if (!event) break;
+
+        qint64 ts = origin_server_ts(*event).toMSecsSinceEpoch();
+        qint64 diff = std::abs(ts - msecsSinceEpoch);
+
+        if (diff < minDiff) {
+            minDiff = diff;
+            closestIdx = mid;
+        }
+
+        if (ts < msecsSinceEpoch) {
+            low = mid + 1;
+        } else if (ts > msecsSinceEpoch) {
+            high = mid - 1;
+        } else {
+            break; // exact match
+        }
+    }
+
+    if (closestIdx != -1)
+        return events.size() - closestIdx - 1;
+    return -1;
+}
