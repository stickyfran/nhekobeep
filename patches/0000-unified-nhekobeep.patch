+void
+TimelineModel::fetchFullRoomHistory()
+{
+    if (m_fullHistoryFetching) {
+        nhlog::ui()->warn("fetchFullRoomHistory: Already fetching full history for room {}",
+                          room_id_.toStdString());
+        return;
+    }
+
+    auto token = cache::client()->previousBatchToken(room_id_.toStdString());
+    if (token.empty()) {
+        nhlog::ui()->info("fetchFullRoomHistory: No previous batch token for room {}",
+                          room_id_.toStdString());
+        return;
+    }
+
+    nhlog::ui()->info("fetchFullRoomHistory: Starting full history fetch for room {}",
+                      room_id_.toStdString());
+
+    m_fullHistoryFetching = true;
+    emit fullHistoryFetchingChanged();
+
+    QTimer::singleShot(0, this, &TimelineModel::fetchFullHistoryPage);
+}
+
+void
+TimelineModel::fetchFullHistoryPage()
+{
+    if (!m_fullHistoryFetching)
+        return;
+
+    auto token = cache::client()->previousBatchToken(room_id_.toStdString());
+    if (token.empty()) {
+        nhlog::ui()->info("fetchFullHistoryPage: No more pages for room {}",
+                          room_id_.toStdString());
+        m_fullHistoryFetching = false;
+        emit fullHistoryFetchingChanged();
+        return;
+    }
+
+    mtx::http::MessagesOpts opts;
+    opts.room_id = room_id_.toStdString();
+    opts.from    = token;
+    opts.limit   = 1000;
+    opts.dir     = mtx::http::PaginationDirection::Backwards;
+
+    nhlog::ui()->debug("fetchFullHistoryPage: Fetching page for room {}, token: {}",
+                       opts.room_id, opts.from);
+
+    http::client()->messages(
+      opts,
+      [this, token](const mtx::responses::Messages &res, mtx::http::RequestErr err) {
+          if (err) {
+              nhlog::net()->error("fetchFullHistoryPage: /messages failed for room {}: {}",
+                                  room_id_.toStdString(), err->matrix_error.error);
+              m_fullHistoryFetching = false;
+              emit fullHistoryFetchingChanged();
+              return;
+          }
+
+          emit events.oldMessagesRetrieved(res);
+
+          if (res.end.empty() || res.end == token) {
+              nhlog::ui()->info("fetchFullRoomHistory: Completed for room {}",
+                                room_id_.toStdString());
+              m_fullHistoryFetching = false;
+              emit fullHistoryFetchingChanged();
+          } else {
+              QTimer::singleShot(0, this, &TimelineModel::fetchFullHistoryPage);
+          }
+      });
+}
+
+void
+TimelineModel::repairRoom() {
+    auto roomId = room_id_.toStdString();
+    nhlog::ui()->info("Repairing room {}", roomId);
+    
+    // Drop per-room databases
+    auto txn = lmdb::txn::begin(cache::client()->env());
+    for (const auto &suffix : {"/events", "/event_order", "/event2order", 
+                                "/msg2order", "/order2msg", "/pending", "/related"}) {
+        try {
+            lmdb::dbi::open(txn, (roomId + suffix).c_str()).drop(txn, true);
+        } catch (...) {}
+    }
+    txn.commit();
+    
+    // Re-fetch via /messages
+    fetchFullRoomHistory();
+}
