+// Given a fully-qualified MXID, extract the localpart prefix and look up
+// the corresponding bridge network info. Returns empty BeeperNetworkInfo
+// when no known bridge prefix matches.
+BeeperNetworkInfo
+beeperNetworkFromMxid(const QString &mxid)
+{
+    // Parse localpart: @prefix_rest:server
+    const auto atPos = mxid.indexOf(QLatin1Char('@'));
+    if (atPos < 0)
+        return {};
+    const auto colonPos = mxid.indexOf(QLatin1Char(':'), atPos + 1);
+    if (colonPos < 0)
+        return {};
+
+    const auto localpart = mxid.mid(atPos + 1, colonPos - atPos - 1);
+
+    // Scan prefix map (longer prefixes first for correctness with e.g.
+    // "instagramgo_" vs "instagram_").
+    for (auto it = kBeeperPrefixMap.constBegin(); it != kBeeperPrefixMap.constEnd(); ++it) {
+        if (localpart.startsWith(it.key(), Qt::CaseInsensitive))
+            return {it.value().first, it.value().second, QString()};
+    }
+
+    // Fallback: extract text before the first underscore, strip trailing
+    // "go" suffix, capitalize.
+    const auto underscorePos = localpart.indexOf(QLatin1Char('_'));
+    if (underscorePos > 0) {
+        auto prefix = localpart.left(underscorePos);
+        if (prefix.endsWith(QStringLiteral("go"), Qt::CaseInsensitive))
+            prefix.chop(2);
+        if (!prefix.isEmpty()) {
+            prefix[0] = prefix[0].toUpper();
+            return {prefix, QColor(), QString()};
+        }
+    }
+
+    return {QString(), QColor(), QString()};
+}
