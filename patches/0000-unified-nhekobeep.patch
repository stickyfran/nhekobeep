+struct BeeperLabelsAccountData {
+    std::map<std::string, BeeperLabel> labels;
+};
+
+inline void to_json(nlohmann::json& j, const BeeperLabelsAccountData& obj) {
+    j = obj.labels;
+}
+
+void CommunitiesModel::updateBeeperLabel(QString uuid, QString name, QString icon)
+{
+    auto pureTag = "beeper:" + uuid;
+    UserSettings::instance()->updateCustomLabel(pureTag, name, icon);
+
+    auto labels = cache::client()->getBeeperLabels();
+    std::string uuid_str = uuid.toStdString();
+    
+    if (labels.count(uuid_str)) {
+        labels[uuid_str].title = name.toStdString();
+        
+        // Nlohmann json serialization
+        BeeperLabelsAccountData accountData;
+        accountData.labels = labels;
+
+        nlohmann::json payload;
+        to_json(payload, accountData);
+        std::string endpoint = "/client/v3/user/" + mtx::client::utils::url_encode(utils::localUser().toStdString()) + "/account_data/com.beeper.labels";
+        
+        http::client()->put(
+            endpoint,
+            payload.dump(),
+            [](mtx::http::HeaderFields, const std::string_view&, int err_code, int status_code) {
+                if (err_code || status_code >= 300) {
+                    nhlog::net()->warn("failed to update beeper label: err={} status={}", err_code, status_code);
+                }
+            },
+            true
+        );
+        
+        // Notify UI that data changed
+        int idx = tags_.indexOf(pureTag);
+        if (idx >= 0) {
+            idx += 1 + spaceOrder_.size();
+            emit dataChanged(index(idx), index(idx));
+        }
+    }
+}
