+
+    QString filter = tr("Text Files (*.txt);;HTML Files (*.html);;JSON Files (*.json)");
+    QString filePath = QFileDialog::getSaveFileName(
+      nullptr, tr("Save Chat History"), roomid + "_history.txt", filter);
+
+    if (filePath.isEmpty())
+        return;
+
+    QString format = QStringLiteral("txt");
+    if (filePath.endsWith(QStringLiteral(".html"), Qt::CaseInsensitive))
+        format = QStringLiteral("html");
+    else if (filePath.endsWith(QStringLiteral(".json"), Qt::CaseInsensitive))
+        format = QStringLiteral("json");
+
+    room->exportChatHistory(filePath, format);
+}
