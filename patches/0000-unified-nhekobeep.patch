+    void
+    TimelineModel::exportChatHistory(const QString &filePath, const QString &format)
+    {
+        QFile file(filePath);
+        if (!file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+            nhlog::ui()->error("Failed to open file for history export: {}",
+                               filePath.toStdString());
