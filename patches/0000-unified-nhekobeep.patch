+    const auto &label = labels_.at(index.row());
+    switch (role) {
+    case TagRole:
+        return label.tag;
+    case DisplayNameRole:
+        return label.displayName;
+    case IconKeyRole:
+        return label.iconKey;
+    default:
+        return {};
+    }
+}
