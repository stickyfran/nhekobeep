+    void
+    TimelineModel::exportChatHistory(const QString &filePath, const QString &format)
+    {
+        QFile file(filePath);
+        if (!file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+            nhlog::ui()->error("Failed to open file for history export: {}",
+                               filePath.toStdString());
+            return;
+        }
+    
+        QTextStream out(&file);
+        out.setEncoding(QStringConverter::Utf8);
+    
+        if (format == QLatin1String("html"))
+            exportChatHistoryToHtml(out);
+        else if (format == QLatin1String("json"))
+            exportChatHistoryToJson(out);
+        else
+            exportChatHistoryToTxt(out);
+    
+        file.close();
+        nhlog::ui()->info("Exported chat history: {} lines, file: {}",
+                          out.status() == QTextStream::Ok ? "OK" : "ERR",
+                          filePath.toStdString());
+    }
+    
+    void
+    TimelineModel::exportChatHistoryToTxt(QTextStream &out)
+    {
+        const QString sep = QString(60, QLatin1Char('='));
+        out << "Chat History - " << plainRoomName() << " (" << roomId() << ")\n";
+        out << sep << "\n\n";
+    
+        int total = 0;
+        int totalEvents = events.size();
+    
+        // Iterate from oldest (0) to newest (size()-1)
+        for (int i = 0; i < totalEvents; ++i) {
+            const auto evt = events.get(i);
+            if (!evt)
+                continue;
+    
+            const auto sender  = QString::fromStdString(mtx::accessors::sender(*evt));
+            const auto body    = QString::fromStdString(mtx::accessors::body(*evt));
+            const auto msgtype = QString::fromStdString(mtx::accessors::msg_type_str(*evt));
+    
+            out << sender << ": ";
+            if (msgtype == QLatin1String("m.text") || msgtype == QLatin1String("m.notice"))
+                out << body;
+            else if (msgtype == QLatin1String("m.emote"))
+                out << "* " << sender << " " << body;
+            else if (msgtype == QLatin1String("m.image"))
+                out << "[Image] " << body;
+            else if (msgtype == QLatin1String("m.file"))
+                out << "[File] " << body;
+            else
+                out << "[" << msgtype << "] " << body;
+    
+            out << "\n";
+            ++total;
+    
+            if (total % 500 == 0)
+                nhlog::ui()->info("History export progress: {} / {}", total, totalEvents);
+        }
+    
+        out << "\n" << sep << "\n";
+        out << "Total messages: " << total << "\n";
+    }
+    
+    void
+    TimelineModel::exportChatHistoryToHtml(QTextStream &out)
+    {
+        out << "<!DOCTYPE html><html><head><meta charset=\"UTF-8\">\n"
+            << "<title>Chat History - " << plainRoomName().toHtmlEscaped() << "</title>\n"
+            << "<style>body{font-family:sans-serif;max-width:800px;margin:auto;padding:20px}"
+            << ".msg{margin:8px 0}.time{color:#888;font-size:0.85em}.sender{font-weight:bold}"
+            << "</style></head><body>\n"
+            << "<h1>" << plainRoomName().toHtmlEscaped() << "</h1>\n"
+            << "<p>Room: " << roomId().toHtmlEscaped() << "</p>\n"
+            << "<hr>\n";
+    
+        int totalEvents = events.size();
+        for (int i = 0; i < totalEvents; ++i) {
+            const auto evt = events.get(i);
+            if (!evt)
+                continue;
+    
+            const auto sender  = QString::fromStdString(mtx::accessors::sender(*evt)).toHtmlEscaped();
+            const auto body =
+              QString::fromStdString(mtx::accessors::body(*evt)).toHtmlEscaped().replace(
+                QLatin1Char('\n'), QStringLiteral("<br>"));
+    
+            out << "<div class=\"msg\">"
+                << "<span class=\"sender\">" << sender << "</span>: "
+                << "<span class=\"body\">" << body << "</span>"
+                << "</div>\n";
+        }
+    
+        out << "<hr></body></html>\n";
+    }
+    
+    void
+    TimelineModel::exportChatHistoryToJson(QTextStream &out)
+    {
+        out << "{\n";
+        out << "  \"roomName\": " << plainRoomName() << ",\n";
+        out << "  \"roomId\": " << roomId() << ",\n";
+        out << "  \"messages\": [\n";
+    
+        int totalEvents = events.size();
+        bool first = true;
+        for (int i = 0; i < totalEvents; ++i) {
+            const auto evt = events.get(i);
+            if (!evt)
+                continue;
+    
+            if (!first)
+                out << ",\n";
+            first = false;
+    
+            const auto sender  = QString::fromStdString(mtx::accessors::sender(*evt));
+            const auto body    = QString::fromStdString(mtx::accessors::body(*evt));
+            const auto msgtype = QString::fromStdString(mtx::accessors::msg_type_str(*evt));
+    
+            out << "    {\n";
+            out << "      \"sender\": " << sender << ",\n";
+            out << "      \"body\": " << body << ",\n";
+            out << "      \"type\": " << msgtype << "\n";
+            out << "    }";
+        }
+    
+        out << "\n  ]\n}\n";
+    }
