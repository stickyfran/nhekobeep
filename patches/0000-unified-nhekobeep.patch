+// SPDX-FileCopyrightText: Nheko Contributors
+//
+// SPDX-License-Identifier: GPL-3.0-or-later
+
+import ".."
+import "../emoji"
+import QtQuick 2.12
+import QtQuick.Controls 2.5
+import QtQuick.Layouts 1.3
+import im.nheko 1.0
+
+ApplicationWindow {
+    id: iconDialog
+
+    property string currentTagId: ""
+    property string initialDisplayName: ""
+    property string initialIcon: ""
+
+    title: qsTr("Edit Label")
+    modality: Qt.NonModal
+    flags: Qt.Dialog
+    width: 350
+    height: 180
+    
+    // The "tag:xyz" or "virtual:abc"
+    property string pureTag: {
+        if (currentTagId.startsWith("tag:"))
+            return currentTagId.substring(4);
+        return currentTagId;
+    }
+
+    Component.onCompleted: {
+        nameInput.text = initialDisplayName ? initialDisplayName : Settings.customLabelDisplayName(pureTag);
+        iconInput.text = initialIcon ? initialIcon : Settings.customLabelIconKey(pureTag);
+        if (iconInput.text.startsWith(":/icons/icons/ui/")) iconInput.text = "";
+        nameInput.forceActiveFocus();
+    }
+
+    Shortcut {
+        sequences: [StandardKey.Cancel]
+        onActivated: iconDialog.close()
+    }
+
+    StickerPicker {
+        id: emojiPopup
+        emoji: true
+    }
+
+    ColumnLayout {
+        spacing: Nheko.paddingMedium
+        anchors.margins: Nheko.paddingMedium
+        anchors.fill: parent
+
+        Label {
+            text: qsTr("Display Name")
+            color: palette.text
+        }
+        MatrixTextField {
+            id: nameInput
+            Layout.fillWidth: true
+            placeholderText: pureTag
+        }
+
+        Label {
+            text: qsTr("Icon")
+            color: palette.text
+        }
+        RowLayout {
+            Layout.fillWidth: true
+            MatrixTextField {
+                id: iconInput
+                Layout.fillWidth: true
+            }
+            Button {
+                id: emojiBtn
+                text: "😀"
+                onClicked: emojiPopup.visible ? emojiPopup.close() : emojiPopup.show(emojiBtn, "global", function (plaintext, markdown) {
+                    iconInput.text = plaintext;
+                    emojiPopup.close();
+                })
+            }
+        }
+    }
+
+    footer: DialogButtonBox {
+        id: dbb
+        standardButtons: DialogButtonBox.Ok | DialogButtonBox.Cancel
+        onAccepted: {
+            if (pureTag.startsWith("beeper:")) {
+                Communities.updateBeeperLabel(pureTag.substring(7), nameInput.text, iconInput.text);
+            } else {
+                Settings.updateCustomLabel(pureTag, nameInput.text, iconInput.text);
+            }
+            iconDialog.close();
+        }
+        onRejected: {
+            iconDialog.close();
+        }
+    }
+}
