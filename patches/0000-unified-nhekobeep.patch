+void
+RoomlistModel::updateNetworkCache(const QString &roomid)
+{
+    // 1. Check standard DMs
+    if (directChatToUser.count(roomid)) {
+        const auto &userId = directChatToUser.at(roomid).front();
+        auto info          = beeperNetworkFromMxid(userId);
+        networkCache.insert(roomid, {info.name, info.color});
+        return;
+    }
+
+    // 2. Check Beeper fake DMs (3-member rooms with bridge bot)
+    if (models.contains(roomid)) {
+        auto room  = models.value(roomid);
+        auto local = cache::client()->localUserId();
+        // Only check if it looks like a 1:1 or 3-member group via member count.
+        // We query at most 4 members for efficiency.
+        auto members = cache::client()->getMembers(roomid.toStdString(), 0, 4);
+        if (members.size() == 3) {
+            for (const auto &m : members) {
+                if (m.user_id == local)
+                    continue;
+                if (m.user_id.contains(QStringLiteral("bot"), Qt::CaseInsensitive) &&
+                    m.user_id.contains(QStringLiteral(":beeper.")))
+                    continue;
+                // This is the real contact
+                auto info = beeperNetworkFromMxid(m.user_id);
+                networkCache.insert(roomid, {info.name, info.color});
+                return;
+            }
+        }
+    }
+
+    // No bridge detected
+    networkCache.insert(roomid, {QString(), QColor()});
+}
+
+void
+RoomlistModel::rebuildNetworkCache()
+{
+    networkCache.clear();
+    networkCache.reserve(static_cast<int>(roomids.size()));
+    for (const auto &roomid : roomids)
+        updateNetworkCache(roomid);
+}
