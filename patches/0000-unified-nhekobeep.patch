+
+void CommunitiesModel::updateBeeperLabel(QString uuid, QString name, QString icon)
+{
+    auto pureTag = "beeper:" + uuid;
+    UserSettings::instance()->updateCustomLabel(pureTag, name, icon);
+
+    auto labels = cache::client()->getBeeperLabels();
+    std::string uuid_str = uuid.toStdString();
+    
+    if (labels.count(uuid_str)) {
+        labels[uuid_str].title = name.toStdString();
+        
+        // Nlohmann json serialization
+        BeeperLabelsAccountData accountData;
+        accountData.labels = labels;
+
+        http::client()->put_account_data("com.beeper.labels", accountData, [](mtx::http::RequestErr err) {
+            if (err) {
+                nhlog::net()->warn("failed to update beeper label: {} {} ({})",
+                                   err->matrix_error.error,
+                                   to_string(err->matrix_error.errcode),
+                                   static_cast<int>(err->status_code));
+            }
+        });
+        
+        // Notify UI that data changed
+        int idx = tags_.indexOf(pureTag);
+        if (idx >= 0) {
+            idx += 1 + spaceOrder_.size();
+            emit dataChanged(index(idx), index(idx));
+        }
+    }
+}
