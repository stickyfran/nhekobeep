+    // Pre-sort rooms by approximate_last_modification_ts descending so that
+    // the initial room list shows the most recently active rooms first.
+    // Without this, rooms appear in alphabetical order (LMDB key iteration
+    // order) and then jump to temporal order as incremental sync updates
+    // arrive, causing visual churn.
+    auto roomIdList = cache::client()->roomIds();
+    std::sort(roomIdList.begin(), roomIdList.end(), [](const QString &a, const QString &b) {
+        auto infoA = cache::singleRoomInfo(a.toStdString());
+        auto infoB = cache::singleRoomInfo(b.toStdString());
+        // Sort descending: rooms with the most recent activity first.
+        if (infoA.approximate_last_modification_ts != infoB.approximate_last_modification_ts)
+            return infoA.approximate_last_modification_ts > infoB.approximate_last_modification_ts;
+        // Tie-break by room name for deterministic ordering.
+        return infoA.name < infoB.name;
+    });
+    for (const auto &id : roomIdList)
+        addRoom(id, true);
 
     nhlog::db()->info("Restored {} rooms from cache", rowCount());
 