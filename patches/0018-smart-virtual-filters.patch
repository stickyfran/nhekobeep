+        } else if (tag == QLatin1String("virtual:groups")) {
+            switch (role) {
+            case CommunitiesModel::Roles::AvatarUrl:
+                return QStringLiteral(":/icons/icons/ui/people.svg");
+            case CommunitiesModel::Roles::DisplayName:
+                return tr("Groups");
+            case CommunitiesModel::Roles::Tooltip:
+                return tr("Group chats.");
+            }
         } else {
             switch (role) {
             case CommunitiesModel::Roles::AvatarUrl:
@@ -362,6 +402,9 @@ CommunitiesModel::initializeSidebar()
     for (const auto &t : ts)
         tags_.push_back(QString::fromStdString(t));
 
+    // Persistent virtual smart filters (stripped from tags() accessor).
+    tags_.push_back(QStringLiteral("virtual:unread"));
+    tags_.push_back(QStringLiteral("virtual:groups"));
+
     spaceOrder_.restoreCollapsed();
 
     for (auto &space : spaceOrder_.tree) {
@@ -700,6 +743,8 @@ namespace {
 enum Categories
 {
     World,
+    VirtualUnread,
+    VirtualGroups,
     Direct,
     Favourites,
     Server,
@@ -715,6 +760,10 @@ tagIdToCat(const QString &tagId)
         return World;
     else if (tagId == QLatin1String("dm"))
         return Direct;
+    else if (tagId == QLatin1String("tag:virtual:unread"))
+        return VirtualUnread;
+    else if (tagId == QLatin1String("tag:virtual:groups"))
+        return VirtualGroups;
     else if (tagId == QLatin1String("tag:m.favourite"))
         return Favourites;
     else if (tagId == QLatin1String("tag:m.server_notice"))
diff --git a/src/timeline/RoomlistModel.h b/src/timeline/RoomlistModel.h
index abcdef1..abcdef2 100644
--- a/src/timeline/RoomlistModel.h
+++ b/src/timeline/RoomlistModel.h
@@ -252,8 +252,10 @@ private:
     enum class FilterBy
     {
         Tag,
         Space,
         DirectChats,
+        VirtualUnread,
+        VirtualGroups,
         Nothing,
     };
     QString filterStr   = QLatin1String("");
diff --git a/src/timeline/RoomlistModel.cpp b/src/timeline/RoomlistModel.cpp
index abcdef1..abcdef2 100644
--- a/src/timeline/RoomlistModel.cpp
+++ b/src/timeline/RoomlistModel.cpp
@@ -222,6 +222,12 @@ FilteredRoomlistModel::updateFilterTag(QString tagId)
         } else if (tagId.startsWith(QLatin1String("dm"))) {
             filterType = FilterBy::DirectChats;
             filterStr.clear();
+        } else if (tagId == QLatin1String("tag:virtual:unread")) {
+            filterType = FilterBy::VirtualUnread;
+            filterStr.clear();
+        } else if (tagId == QLatin1String("tag:virtual:groups")) {
+            filterType = FilterBy::VirtualGroups;
+            filterStr.clear();
         } else {
             filterType = FilterBy::Nothing;
             filterStr.clear();
@@ -1176,6 +1182,63 @@ FilteredRoomlistModel::filterAcceptsRow(int sourceRow, const QModelIndex &) cons
         }
 
         return true;
+    } else if (filterType == FilterBy::VirtualUnread) {
+        // Hide spaces and unfetched previews from the unread filter.
+        if (sourceModel()
+              ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::IsPreview)
+              .toBool()) {
+            return false;
+        }
+
+        if (sourceModel()
+              ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::IsSpace)
+              .toBool()) {
+            return false;
+        }
+
+        if (!hiddenTags.empty()) {
+            auto tags = sourceModel()
+                          ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::Tags)
+                          .toStringList();
+
+            for (const auto &t : std::as_const(tags))
+                if (hiddenTags.contains(t))
+                    return false;
+        }
+
+        if (!hiddenSpaces.empty()) {
+            auto parents = sourceModel()
+                             ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::ParentSpaces)
+                             .toStringList();
+            for (const auto &t : std::as_const(parents))
+                if (hiddenSpaces.contains(t))
+                    return false;
+        }
+
+        bool hasUnread =
+          sourceModel()
+            ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::HasUnreadMessages)
+            .toBool();
+        int notifCount =
+          sourceModel()
+            ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::NotificationCount)
+            .toInt();
+
+        return hasUnread || notifCount > 0;
+    } else if (filterType == FilterBy::VirtualGroups) {
+        if (sourceModel()
+              ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::IsPreview)
+              .toBool()) {
+            return false;
+        }
+
+        if (sourceModel()
+              ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::IsSpace)
+              .toBool()) {
+            return false;
+        }
+
+        // Accept only non-direct-chat rooms (i.e. group rooms).
+        return !sourceModel()
+                    ->data(sourceModel()->index(sourceRow, 0), RoomlistModel::IsDirect)
+                    .toBool();
     } else {
         return true;
     }
