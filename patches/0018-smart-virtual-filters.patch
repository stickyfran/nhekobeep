# patches/0018-smart-virtual-filters.patch
#
# Epic 3: Smart Virtual Filters ("Unread" & "Groups")
#
# Injects two persistent virtual sidebar tags ("virtual:unread" and
# "virtual:groups") into the CommunitiesModel and wires their filtering
# logic in FilteredRoomlistModel::filterAcceptsRow.
#
# "virtual:unread" — shows only rooms with unread messages or pending
#                     notifications.
# "virtual:groups"  — shows only rooms that are NOT direct chats (group
#                     rooms, including Beeper-bridged multi-user rooms).
#
# Both virtual tags are stripped from the tags() accessor so they never
# appear in right-click "Tag room as..." context menus.
#
# == Changes ==
#
# 1. src/timeline/CommunitiesModel.h
#    - Move tags() implementation from inline to .cpp (now filters out
#      entries that start with "virtual:")
#    - Update tagsWithDefault() to call tags() instead of reading tags_
#      directly
#
# 2. src/timeline/CommunitiesModel.cpp
#    - initializeSidebar(): push "virtual:unread" and "virtual:groups"
#      into tags_ after collecting real tags
#    - tags() (NEW out-of-line): return tags_ minus "virtual:*" entries
#    - tagsWithDefault(): delegate to tags() for the base list
#    - data(): handle "virtual:unread" and "virtual:groups" in the tag
#      branch — assign alert.svg / people.svg icons, tr("Unread") /
#      tr("Groups") display names
#    - tagIdToCat(): add VirtualUnread / VirtualGroups categories so
#      they sort after Direct Chats and before Favourites in the sidebar
#
# 3. src/timeline/RoomlistModel.h
#    - Add VirtualUnread and VirtualGroups to the FilterBy enum
#
# 4. src/timeline/RoomlistModel.cpp
#    - updateFilterTag(): accept "tag:virtual:unread" and
#      "tag:virtual:groups" and set filterType accordingly
#    - filterAcceptsRow(VirtualUnread): accept if HasUnreadMessages is
#      true OR NotificationCount > 0
#    - filterAcceptsRow(VirtualGroups): accept if IsDirect is false
#
diff --git a/src/timeline/CommunitiesModel.h b/src/timeline/CommunitiesModel.h
index abcdef1..abcdef2 100644
--- a/src/timeline/CommunitiesModel.h
+++ b/src/timeline/CommunitiesModel.h
@@ -211,18 +211,10 @@ public:
     void resetCurrentTagId()
     {
         currentTagId_.clear();
         emit currentTagIdChanged(currentTagId_);
     }
-    QStringList tags() const { return tags_; }
-    QStringList tagsWithDefault() const
-    {
-        QStringList tagsWD = tags_;
-        tagsWD.prepend(QStringLiteral("m.lowpriority"));
-        tagsWD.prepend(QStringLiteral("m.favourite"));
-        tagsWD.removeOne(QStringLiteral("m.server_notice"));
-        tagsWD.removeDuplicates();
-        return tagsWD;
-    }
+    QStringList tags() const;
+    QStringList tagsWithDefault() const;
     void toggleTagId(QString tagId);
     void toggleTagMute(QString tagId);
 
diff --git a/src/timeline/CommunitiesModel.cpp b/src/timeline/CommunitiesModel.cpp
index abcdef1..abcdef2 100644
--- a/src/timeline/CommunitiesModel.cpp
+++ b/src/timeline/CommunitiesModel.cpp
@@ -27,6 +27,22 @@ CommunitiesModel::CommunitiesModel(QObject *parent)
     instance_ = this;
 }
 
+QStringList
+CommunitiesModel::tags() const
+{
+    QStringList result;
+    for (const auto &t : tags_)
+        if (!t.startsWith(QLatin1String("virtual:")))
+            result.push_back(t);
+    return result;
+}
+
+QStringList
+CommunitiesModel::tagsWithDefault() const
+{
+    auto t = tags();
+    t.removeOne(QStringLiteral("m.server_notice"));
+    t.removeDuplicates();
+    t.prepend(QStringLiteral("m.lowpriority"));
+    t.prepend(QStringLiteral("m.favourite"));
+    return t;
+}
+
 QHash<int, QByteArray>
 CommunitiesModel::roleNames() const
 {
@@ -160,7 +176,31 @@ CommunitiesModel::data(const QModelIndex &index, int role) const
         } else if (tag == QLatin1String("m.server_notice")) {
             switch (role) {
             case CommunitiesModel::Roles::AvatarUrl:
                 return QStringLiteral(":/icons/icons/ui/tag.svg");
             case CommunitiesModel::Roles::DisplayName:
                 return tr("Server Notices");
             case CommunitiesModel::Roles::Tooltip:
                 return tr("Messages from your server or administrator.");
             }
