# patches/0015-custom-label-emoji-editor.patch
#
# Custom Label Emoji Editor & Emoji Icon Display
#
# Provides a QML UI for managing custom labels with emoji-based icons
# (instead of the original SVG-icon ComboBox approach), and updates the
# CommunitiesList sidebar to render emoji icons as text labels rather
# than attempting to load them as image URLs.
#
# == Changes ==
#
# 1. resources/qml/pages/UserSettingsPage.qml
#    - Add a "MANAGE" DelegateChoice button for ManageCustomLabelsAction
#      (alongside the existing ManageIgnoredUsers entry).
#    - Add a full-featured Custom Label Editor Dialog with:
#      * Inline editing of label name + emoji icon for each existing label
#      * Per-row "Save" button (explicit save, not auto-save on text change)
#      * Delete button per row
#      * "Add Custom Label" sub-dialog with fields for tag, name, and emoji
#      * Emoji TextField with single-character auto-truncation
#
# 2. resources/qml/CommunitiesList.qml
#    - Introduce `isEmojiIcon` read-only property on the item delegate that
#      detects non-path avatarUrl values (values that do not start with
#      "mxc://", ":/" or "image://").
#    - When isEmojiIcon is true, render a centered Label inside a rounded
#      Rectangle instead of the standard Avatar component, so that emoji
#      characters (e.g. 💼, 🍻, ❤️) appear natively as large text.
#    - The standard Avatar path is preserved and shown when isEmojiIcon is
#      false (backward-compatible).
#
# == Dependencies ==
#
# Requires the C++ backend from archive/0008-custom-labels-cpp.patch
# (CustomLabel struct, CustomLabelListModel singleton, UserSettings
# persistence methods).  Without that backend, the QML ManageCustomLabelsAction
# DelegateChoice will not match any model role and will be silently skipped.
#
diff --git a/resources/qml/CommunitiesList.qml b/resources/qml/CommunitiesList.qml
index a134474..0d2f6ff 100644
--- a/resources/qml/CommunitiesList.qml
+++ b/resources/qml/CommunitiesList.qml
@@ -139,7 +139,57 @@ Page {
                     Layout.preferredWidth: fontMetrics.lineSpacing
                     visible: !communitySidebar.collapsed && !model.collapsible && Communities.containsSubspaces
                 }
+
+                // Determine if the avatarUrl is an emoji (custom label icon) or a real image path.
+                readonly property bool isEmojiIcon: {
+                    if (!model.avatarUrl || model.avatarUrl.length === 0)
+                        return false;
+                    // Image paths start with known prefixes; anything else is treated as an emoji/text icon.
+                    if (model.avatarUrl.startsWith("mxc://") ||
+                        model.avatarUrl.startsWith(":/") ||
+                        model.avatarUrl.startsWith("image://"))
+                        return false;
+                    return true;
+                }
+
+                // Emoji icon display (for custom label emoji icons).
+                Item {
+                    Layout.alignment: Qt.AlignVCenter
+                    Layout.preferredHeight: avatarSize
+                    Layout.preferredWidth: avatarSize
+                    visible: isEmojiIcon
+
+                    Rectangle {
+                        anchors.fill: parent
+                        color: communityItem.backgroundColor
+                        radius: Settings.avatarCircles ? height / 2 : height / 8
+
+                        Label {
+                            anchors.centerIn: parent
+                            text: model.avatarUrl
+                            font.pixelSize: avatarSize * 0.55
+                            horizontalAlignment: Text.AlignHCenter
+                            verticalAlignment: Text.AlignVCenter
+                            textFormat: Text.PlainText
+                        }
+                    }
+
+                    NotificationBubble {
+                        anchors.bottom: parent.bottom
+                        anchors.margins: -Nheko.paddingSmall
+                        anchors.right: parent.right
+                        bubbleBackgroundColor: communityItem.bubbleBackground
+                        bubbleTextColor: communityItem.bubbleText
+                        font.pixelSize: fontMetrics.font.pixelSize * 0.6
+                        hasLoudNotification: model.hasLoudNotification
+                        mayBeVisible: communitySidebar.collapsed && !model.muted && Settings.spaceNotifications
+                        notificationCount: model.unreadMessages
+                    }
+                }
+
+                // Standard avatar display (for MXC, SVG, and image provider icons).
                 Avatar {
+                    visible: !isEmojiIcon
                     id: avatar
 
                     Layout.alignment: Qt.AlignVCenter
diff --git a/resources/qml/pages/UserSettingsPage.qml b/resources/qml/pages/UserSettingsPage.qml
index 8f51e66..ff09c17 100644
--- a/resources/qml/pages/UserSettingsPage.qml
