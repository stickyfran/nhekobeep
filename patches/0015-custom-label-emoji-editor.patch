                                 text: model.value
@@ -263,6 +275,189 @@ Rectangle {
         }
     }
 
+    // --- Custom Label Editor Dialog ---
+    Component {
+        id: customLabelEditorComponent
+
+        Dialog {
+            id: customLabelEditor
+            title: qsTr("Custom Label Editor")
+            standardButtons: Dialog.Close
+            modal: true
+            anchors.centerIn: parent
+            width: Math.min(520, parent ? parent.width * 0.92 : 520)
+
+            ColumnLayout {
+                spacing: Nheko.paddingMedium
+                width: parent ? parent.width - Nheko.paddingLarge * 2 : 480
+
+                Label {
+                    text: qsTr("Define custom names and emoji icons for your tags.")
+                    wrapMode: Text.WordWrap
+                    Layout.fillWidth: true
+                }
+
+                ScrollView {
+                    Layout.fillWidth: true
+                    Layout.preferredHeight: Math.min(400, customLabelEditor.height * 0.6)
+                    clip: true
+
+                    ScrollBar.vertical.policy: ScrollBar.AsNeeded
+
+                    ColumnLayout {
+                        width: parent ? parent.width : 460
+                        spacing: Nheko.paddingSmall
+
+                        Repeater {
+                            id: labelRepeater
+                            model: CustomLabelListModel
+
+                            delegate: RowLayout {
+                                id: labelRow
+                                Layout.fillWidth: true
+                                spacing: Nheko.paddingSmall
+
+                                required property int index
+                                required property string tag
+                                required property string displayName
+                                required property string iconKey
+
+                                // Local editing state
+                                property string editedName: displayName
+                                property string editedIcon: iconKey
+
+                                TextField {
+                                    Layout.fillWidth: true
+                                    placeholderText: qsTr("Label Name")
+                                    text: labelRow.editedName
+                                    onTextChanged: labelRow.editedName = text
+                                }
+
+                                TextField {
+                                    id: iconField
+                                    Layout.preferredWidth: 50
+                                    Layout.maximumWidth: 60
+                                    placeholderText: qsTr("💼")
+                                    text: {
+                                        // If existing icon is an emoji (not a path), show it.
+                                        if (labelRow.editedIcon.length > 0 &&
+                                            !labelRow.editedIcon.startsWith(":/") &&
+                                            !labelRow.editedIcon.startsWith("mxc://") &&
+                                            !labelRow.editedIcon.startsWith("image://")) {
+                                            return labelRow.editedIcon;
+                                        }
+                                        return "";
+                                    }
+                                    onTextChanged: {
+                                        if (text.length > 1) {
+                                            // Keep only the first character.
+                                            labelRow.editedIcon = text.charAt(0);
+                                            iconField.text = labelRow.editedIcon;
+                                        } else {
+                                            labelRow.editedIcon = text;
+                                        }
+                                    }
+                                    ToolTip.text: qsTr("Enter a single emoji character")
+                                    ToolTip.visible: hovered
+                                    ToolTip.delay: Nheko.tooltipDelay
+                                }
+
+                                Label {
+                                    text: labelRow.tag
+                                    color: palette.buttonText
+                                    font.pixelSize: fontMetrics.font.pixelSize * 0.85
+                                    Layout.preferredWidth: 80
+                                    elide: Text.ElideRight
+                                }
+
+                                Button {
+                                    text: qsTr("Save")
+                                    enabled: labelRow.editedName.length > 0 &&
+                                             (labelRow.editedName !== labelRow.displayName ||
+                                              labelRow.editedIcon !== labelRow.iconKey)
+                                    onClicked: {
+                                        CustomLabelListModel.updateLabel(
+                                            labelRow.index,
+                                            labelRow.tag,
+                                            labelRow.editedName,
+                                            labelRow.editedIcon.length > 0 ? labelRow.editedIcon : labelRow.iconKey);
+                                    }
+                                }
+
+                                ImageButton {
+                                    Layout.preferredWidth: 22
+                                    Layout.preferredHeight: 22
+                                    image: ":/icons/icons/ui/delete.svg"
+                                    ToolTip.text: qsTr("Remove label")
+                                    ToolTip.visible: hovered
+                                    hoverEnabled: true
+                                    onClicked: CustomLabelListModel.removeLabel(labelRow.index)
+                                }
+                            }
+                        }
+
+                        Button {
+                            text: qsTr("Add Custom Label")
+                            Layout.alignment: Qt.AlignLeft
+                            onClicked: addLabelDialog.open()
+                        }
+                    }
+                }
+            }
+
+            // --- Add Label Dialog ---
+            Dialog {
+                id: addLabelDialog
+                title: qsTr("Add Custom Label")
+                standardButtons: Dialog.Ok | Dialog.Cancel
+                modal: true
+                anchors.centerIn: parent
+
+                ColumnLayout {
+                    spacing: Nheko.paddingMedium
+                    width: parent ? parent.width : 300
+
+                    Label { text: qsTr("Tag:") }
+                    TextField {
+                        id: newTagField
+                        placeholderText: "u.mylabel"
+                        Layout.fillWidth: true
+                    }
+
+                    Label { text: qsTr("Label Name:") }
+                    TextField {
+                        id: newNameField
+                        placeholderText: qsTr("My Label")
+                        Layout.fillWidth: true
+                    }
+
+                    Label { text: qsTr("Icon (emoji):") }
+                    TextField {
+                        id: newIconField
+                        placeholderText: qsTr("💼")
+                        Layout.fillWidth: true
+                        onTextChanged: {
+                            if (text.length > 1)
+                                text = text.charAt(0);
+                        }
+                    }
+                }
+
+                onAccepted: {
+                    if (newTagField.text && newNameField.text) {
+                        CustomLabelListModel.addLabel(
+                            newTagField.text,
+                            newNameField.text,
+                            newIconField.text.length > 0 ? newIconField.text : "");
+                    }
+                    newTagField.text = "";
+                    newNameField.text = "";
+                    newIconField.text = "";
+                }
+            }
+        }
+    }
+
     ImageButton {
         id: backButton
         anchors.top: parent.top
