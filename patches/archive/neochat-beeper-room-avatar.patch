+namespace {
+struct BeeperPeerInfo {
+    QString userId;
+    QUrl avatarUrl;
+};
+
+bool isBeeperBridgeBotMxid(const QString &mxid)
+{
+    if (!mxid.startsWith(u'@') || !mxid.contains(u':')) {
+        return false;
+    }
+    const auto colon = mxid.indexOf(u':');
+    const QString localpart = mxid.mid(1, colon - 1);
+    const QString server = mxid.mid(colon + 1);
+    if (!server.startsWith(u"beeper."_s, Qt::CaseInsensitive)) {
+        return false;
+    }
+    return localpart.contains(u"bot"_s, Qt::CaseInsensitive);
+}
+
+std::optional<BeeperPeerInfo> beeperBridgedPeer(const NeoChatRoom *room)
+{
+    if (room->joinedCount() != 3) {
+        return std::nullopt;
+    }
+
+    const QString localId = room->localMember().id();
+    bool seenBot = false;
+    int peerCount = 0;
+    QString peerId;
+    QUrl peerAvatar;
+
+    for (const RoomMember &m : room->joinedMembers()) {
+        if (m.isEmpty() || m.membershipState() != Membership::Join) {
+            continue;
+        }
+        if (m.id() == localId) {
+            continue;
+        }
+        if (isBeeperBridgeBotMxid(m.id())) {
+            seenBot = true;
+            continue;
+        }
+        ++peerCount;
+        peerId = m.id();
+        peerAvatar = m.avatarUrl();
+    }
+    if (seenBot && peerCount == 1) {
+        return BeeperPeerInfo{std::move(peerId), peerAvatar};
+    }
+    return std::nullopt;
+}
+} // namespace
