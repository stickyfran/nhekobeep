+// -----------------------------------------------------------------------
+// Beeper Custom Label persistence
+// -----------------------------------------------------------------------
+void
+UserSettings::loadCustomLabels()
+{
+    customLabels_.clear();
+    auto raw = settings.value("user/beeper_custom_labels").toList();
+    for (const auto &item : std::as_const(raw)) {
+        auto map = item.toMap();
+        CustomLabel label;
+        label.tag         = map.value("tag").toString();
+        label.displayName = map.value("displayName").toString();
+        label.iconKey     = map.value("iconKey").toString();
+        if (!label.tag.isEmpty() && !label.displayName.isEmpty())
+            customLabels_.append(QVariant::fromValue(label));
+    }
+}
+
+void
+UserSettings::addCustomLabel(const QString &tag,
+                              const QString &displayName,
+                              const QString &iconKey)
+{
+    for (int i = 0; i < customLabels_.size(); ++i) {
+        auto label = customLabels_[i].value<CustomLabel>();
+        if (label.tag == tag) {
+            customLabels_[i] = QVariant::fromValue(CustomLabel{tag, displayName, iconKey});
+            saveCustomLabels();
+            emit customLabelsChanged();
+            return;
+        }
+    }
+    customLabels_.append(QVariant::fromValue(CustomLabel{tag, displayName, iconKey}));
+    saveCustomLabels();
+    emit customLabelsChanged();
+}
+
+void
+UserSettings::removeCustomLabel(const QString &tag)
+{
+    customLabels_.erase(std::remove_if(customLabels_.begin(),
+                                        customLabels_.end(),
+                                        [&tag](const QVariant &v) {
+                                            return v.value<CustomLabel>().tag == tag;
+                                        }),
+                         customLabels_.end());
+    saveCustomLabels();
+    emit customLabelsChanged();
+}
+
+void
+UserSettings::updateCustomLabel(const QString &tag,
+                                 const QString &displayName,
+                                 const QString &iconKey)
+{
+    for (auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == tag) {
+            v = QVariant::fromValue(CustomLabel{tag, displayName, iconKey});
+            saveCustomLabels();
+            emit customLabelsChanged();
+            return;
+        }
+    }
+    addCustomLabel(tag, displayName, iconKey);
+}
+
+QString
+UserSettings::customLabelDisplayName(const QString &rawTag) const
+{
+    for (const auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == rawTag)
+            return label.displayName;
+    }
+    return {};
+}
+
+QString
+UserSettings::customLabelIconKey(const QString &rawTag) const
+{
+    for (const auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == rawTag)
+            return label.iconKey;
+    }
+    return {};
+}
+
+void
+UserSettings::saveCustomLabels()
+{
+    QVariantList raw;
+    raw.reserve(customLabels_.size());
+    for (const auto &v : std::as_const(customLabels_)) {
+        auto label = v.value<CustomLabel>();
+        QVariantMap map;
+        map["tag"]         = label.tag;
+        map["displayName"] = label.displayName;
+        map["iconKey"]     = label.iconKey;
+        raw.append(map);
+    }
+    settings.setValue("user/beeper_custom_labels", raw);
+}
+
+// -----------------------------------------------------------------------
+// CustomLabelListModel
+// -----------------------------------------------------------------------
+CustomLabelListModel::CustomLabelListModel(QObject *parent)
+  : QAbstractListModel(parent)
+{
+    instance_ = this;
+    connect(UserSettings::instance().get(),
+            &UserSettings::customLabelsChanged,
+            this,
+            &CustomLabelListModel::refreshFromSettings);
+    refreshFromSettings();
+}
+
+CustomLabelListModel *
+CustomLabelListModel::create(QQmlEngine *, QJSEngine *)
+{
+    Q_ASSERT(instance_);
+    QJSEngine::setObjectOwnership(instance_, QJSEngine::CppOwnership);
+    return instance_;
+}
+
+QHash<int, QByteArray>
+CustomLabelListModel::roleNames() const
+{
+    return {
+      {TagRole, "tag"},
+      {DisplayNameRole, "displayName"},
+      {IconKeyRole, "iconKey"},
+    };
+}
+
+QVariant
+CustomLabelListModel::data(const QModelIndex &index, int role) const
+{
+    if (index.row() < 0 || index.row() >= labels_.size())
+        return {};
+
+    const auto &label = labels_.at(index.row());
+    switch (role) {
+    case TagRole:
+        return label.tag;
+    case DisplayNameRole:
+        return label.displayName;
+    case IconKeyRole:
+        return label.iconKey;
+    default:
+        return {};
+    }
+}
+
+void
+CustomLabelListModel::addLabel(const QString &tag,
+                                const QString &displayName,
+                                const QString &iconKey)
+{
+    UserSettings::instance()->addCustomLabel(tag, displayName, iconKey);
+}
+
+void
+CustomLabelListModel::removeLabel(int row)
+{
+    if (row >= 0 && row < labels_.size())
+        UserSettings::instance()->removeCustomLabel(labels_.at(row).tag);
+}
+
+void
+CustomLabelListModel::updateLabel(int row,
+                                   const QString &tag,
+                                   const QString &displayName,
+                                   const QString &iconKey)
+{
+    if (row >= 0 && row < labels_.size())
+        UserSettings::instance()->updateCustomLabel(tag, displayName, iconKey);
+}
+
+QStringList
+CustomLabelListModel::availableIcons() const
+{
+    return {
+      QStringLiteral(":/icons/icons/ui/tag.svg"),
+      QStringLiteral(":/icons/icons/ui/star.svg"),
+      QStringLiteral(":/icons/icons/ui/bookmark.svg"),
+      QStringLiteral(":/icons/icons/ui/chat.svg"),
+      QStringLiteral(":/icons/icons/ui/clock.svg"),
+      QStringLiteral(":/icons/icons/ui/building-shop.svg"),
+      QStringLiteral(":/icons/icons/ui/people.svg"),
+      QStringLiteral(":/icons/icons/ui/world.svg"),
+      QStringLiteral(":/icons/icons/ui/alert.svg"),
+      QStringLiteral(":/icons/icons/ui/checkmark.svg"),
+    };
+}
+
+QString
+CustomLabelListModel::displayNameForTag(const QString &tag) const
+{
+    return UserSettings::instance()->customLabelDisplayName(tag);
+}
+
+QString
+CustomLabelListModel::iconKeyForTag(const QString &tag) const
+{
+    return UserSettings::instance()->customLabelIconKey(tag);
+}
+
+void
+CustomLabelListModel::refreshFromSettings()
+{
+    beginResetModel();
+    labels_.clear();
+    auto custom = UserSettings::instance()->customLabels();
+    for (const auto &v : std::as_const(custom))
+        labels_.append(v.value<CustomLabel>());
+    endResetModel();
+}
