+// -----------------------------------------------------------------------
+// CustomLabelListModel
+// -----------------------------------------------------------------------
+CustomLabelListModel::CustomLabelListModel(QObject *parent)
+  : QAbstractListModel(parent)
+{
+    instance_ = this;
+    connect(UserSettings::instance().get(),
+            &UserSettings::customLabelsChanged,
+            this,
+            &CustomLabelListModel::refreshFromSettings);
+    refreshFromSettings();
+}
+
+CustomLabelListModel *
+CustomLabelListModel::create(QQmlEngine *, QJSEngine *)
+{
+    Q_ASSERT(instance_);
+    QJSEngine::setObjectOwnership(instance_, QJSEngine::CppOwnership);
+    return instance_;
+}
+
+QHash<int, QByteArray>
+CustomLabelListModel::roleNames() const
+{
+    return {
+      {TagRole, "tag"},
+      {DisplayNameRole, "displayName"},
+      {IconKeyRole, "iconKey"},
+    };
+}
+
+QVariant
+CustomLabelListModel::data(const QModelIndex &index, int role) const
+{
+    if (index.row() < 0 || index.row() >= labels_.size())
+        return {};
+
+    const auto &label = labels_.at(index.row());
+    switch (role) {
+    case TagRole:
+        return label.tag;
+    case DisplayNameRole:
+        return label.displayName;
+    case IconKeyRole:
+        return label.iconKey;
+    default:
+        return {};
+    }
+}
+
+void
+CustomLabelListModel::addLabel(const QString &tag,
+                                const QString &displayName,
+                                const QString &iconKey)
+{
+    UserSettings::instance()->addCustomLabel(tag, displayName, iconKey);
+}
+
+void
+CustomLabelListModel::removeLabel(int row)
+{
+    if (row >= 0 && row < labels_.size())
+        UserSettings::instance()->removeCustomLabel(labels_.at(row).tag);
+}
+
+void
+CustomLabelListModel::updateLabel(int row,
+                                   const QString &tag,
+                                   const QString &displayName,
+                                   const QString &iconKey)
+{
+    if (row >= 0 && row < labels_.size())
+        UserSettings::instance()->updateCustomLabel(tag, displayName, iconKey);
+}
+
+QStringList
+CustomLabelListModel::availableIcons() const
+{
+    return {
+      QStringLiteral(":/icons/icons/ui/tag.svg"),
+      QStringLiteral(":/icons/icons/ui/star.svg"),
+      QStringLiteral(":/icons/icons/ui/bookmark.svg"),
+      QStringLiteral(":/icons/icons/ui/chat.svg"),
+      QStringLiteral(":/icons/icons/ui/clock.svg"),
+      QStringLiteral(":/icons/icons/ui/building-shop.svg"),
+      QStringLiteral(":/icons/icons/ui/people.svg"),
+      QStringLiteral(":/icons/icons/ui/world.svg"),
+      QStringLiteral(":/icons/icons/ui/alert.svg"),
+      QStringLiteral(":/icons/icons/ui/checkmark.svg"),
+    };
+}
+
+QString
+CustomLabelListModel::displayNameForTag(const QString &tag) const
+{
+    return UserSettings::instance()->customLabelDisplayName(tag);
+}
+
+QString
+CustomLabelListModel::iconKeyForTag(const QString &tag) const
+{
+    return UserSettings::instance()->customLabelIconKey(tag);
+}
+
+void
+CustomLabelListModel::refreshFromSettings()
+{
+    beginResetModel();
+    labels_.clear();
+    auto custom = UserSettings::instance()->customLabels();
+    for (const auto &v : std::as_const(custom))
+        labels_.append(v.value<CustomLabel>());
+    endResetModel();
+}
