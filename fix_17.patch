+// -----------------------------------------------------------------------
+// Beeper Custom Label persistence
+// -----------------------------------------------------------------------
+void
+UserSettings::loadCustomLabels()
+{
+    customLabels_.clear();
+    auto raw = settings.value("user/beeper_custom_labels").toList();
+    for (const auto &item : std::as_const(raw)) {
+        auto map = item.toMap();
+        CustomLabel label;
+        label.tag         = map.value("tag").toString();
+        label.displayName = map.value("displayName").toString();
+        label.iconKey     = map.value("iconKey").toString();
+        if (!label.tag.isEmpty() && !label.displayName.isEmpty())
+            customLabels_.append(QVariant::fromValue(label));
+    }
+}
+
+void
+UserSettings::addCustomLabel(const QString &tag,
+                              const QString &displayName,
+                              const QString &iconKey)
+{
+    for (int i = 0; i < customLabels_.size(); ++i) {
+        auto label = customLabels_[i].value<CustomLabel>();
+        if (label.tag == tag) {
+            customLabels_[i] = QVariant::fromValue(CustomLabel{tag, displayName, iconKey});
+            saveCustomLabels();
+            emit customLabelsChanged();
+            return;
+        }
+    }
+    customLabels_.append(QVariant::fromValue(CustomLabel{tag, displayName, iconKey}));
+    saveCustomLabels();
+    emit customLabelsChanged();
+}
+
+void
+UserSettings::removeCustomLabel(const QString &tag)
+{
+    customLabels_.erase(std::remove_if(customLabels_.begin(),
+                                        customLabels_.end(),
+                                        [&tag](const QVariant &v) {
+                                            return v.value<CustomLabel>().tag == tag;
+                                        }),
+                         customLabels_.end());
+    saveCustomLabels();
+    emit customLabelsChanged();
+}
+
+void
+UserSettings::updateCustomLabel(const QString &tag,
+                                 const QString &displayName,
+                                 const QString &iconKey)
+{
+    for (auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == tag) {
+            v = QVariant::fromValue(CustomLabel{tag, displayName, iconKey});
+            saveCustomLabels();
+            emit customLabelsChanged();
+            return;
+        }
+    }
+    addCustomLabel(tag, displayName, iconKey);
+}
+
+QString
+UserSettings::customLabelDisplayName(const QString &rawTag) const
+{
+    for (const auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == rawTag)
+            return label.displayName;
+    }
+    return {};
+}
+
+QString
+UserSettings::customLabelIconKey(const QString &rawTag) const
+{
+    for (const auto &v : customLabels_) {
+        auto label = v.value<CustomLabel>();
+        if (label.tag == rawTag)
+            return label.iconKey;
+    }
+    return {};
+}
+
+void
+UserSettings::saveCustomLabels()
+{
+    QVariantList raw;
+    raw.reserve(customLabels_.size());
+    for (const auto &v : std::as_const(customLabels_)) {
+        auto label = v.value<CustomLabel>();
+        QVariantMap map;
+        map["tag"]         = label.tag;
+        map["displayName"] = label.displayName;
+        map["iconKey"]     = label.iconKey;
+        raw.append(map);
+    }
+    settings.setValue("user/beeper_custom_labels", raw);
+}
